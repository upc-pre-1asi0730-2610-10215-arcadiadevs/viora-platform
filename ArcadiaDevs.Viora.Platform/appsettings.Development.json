{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Database": {
    "Provider": "InMemory"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=%DATABASE_URL%;Port=%DATABASE_PORT%;Database=%DATABASE_SCHEMA%;Username=%DATABASE_USER%;Password=%DATABASE_PASSWORD%"
  },
  "ExternalApis": {
    "AgroMonitoring": {
      "BaseUrl": "https://api.agromonitoring.com/agro/1.0",
      "ApiKey": "%AGROMONITORING_API_KEY%"
    }
  },
  "AllowedHosts": "*"
}
