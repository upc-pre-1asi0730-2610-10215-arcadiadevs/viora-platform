{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Database": {
    "Provider": "InMemory"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=%DATABASE_URL%;Port=%DATABASE_PORT%;Database=%DATABASE_SCHEMA%;Username=%DATABASE_USER%;Password=%DATABASE_PASSWORD%;Search Path=%DATABASE_SCHEMA%"
  },
  "ExternalApis": {
    "AgroMonitoring": {
      "BaseUrl": "https://api.agromonitoring.com/agro/1.0",
      "ApiKey": "%AGROMONITORING_API_KEY%"
    }
  },
  "Agronomic": {
    "Weather": {
      "AgroMonitoring": {
        "ApiKey": "%AGROMONITORING_WEATHER_API_KEY%"
      }
    },
    "DynamicNutrition": {
      "TemperatureReferenceCelsius": 20.0,
      "HighRiskNdviThreshold": 0.30,
      "ModerateRiskNdviThreshold": 0.50,
      "HighRiskWindowDays": 14,
      "ExtremeRiskWindowDays": 21,
      "FoliarSupportDosageLitersPerHectare": 2.5,
      "PotassiumCalciumDosageKilogramsPerHectare": 3.0,
      "BiostimulantDosageLitersPerHectare": 1.2,
      "ChillDeficitRatio": 0.7
    },
    "Statistics": {
      "ScheduledIngestionEnabled": false,
      "IngestionCron": "0 0 2 * * *"
    }
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "viora-platform",
    "Audience": "viora-platform"
  },
  "AllowedHosts": "*"
}
