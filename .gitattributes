# Normalize line endings to LF in the repository
* text=auto eol=lf

# C# source and project files
*.cs       text eol=lf
*.csproj   text eol=lf
*.sln      text eol=lf
*.resx     text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.http     text eol=lf
*.yaml     text eol=lf
*.yml      text eol=lf
*.editorconfig text eol=lf
Dockerfile text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files (never normalize)
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.pdf      binary
*.zip      binary
*.dll      binary
*.exe      binary
*.nupkg    binary
*.snupkg   binary
*.pfx      binary
*.snk      binary
